# E-Sim By ELECTRON - Backend Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Stripe API Keys (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@esim-electron.com

# eSIM Provider API (for real activation)
ESIM_API_KEY=your_esim_provider_api_key
ESIM_API_URL=https://api.esim-provider.com

# Database (for production - use PostgreSQL/MySQL)
DATABASE_URL=postgresql://user:password@localhost:5432/esim_db
