# E-Sim By ELECTRON - Production Environment

# Server
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/esim
DATABASE_URL=

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@esim-electron.com

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Security
CORS_ORIGIN=https://esim-electron.com
RATE_LIMIT=100

# Logging
LOG_LEVEL=info

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# eSIM Provider (optional)
GIGSKY_API_KEY=
TATA_CLIENT_ID=
TRUPHONE_API_KEY=

# Analytics
GA_TRACKING_ID=G-XXXXXXXXXX
GTM_CONTAINER_ID=GTM-XXXXXXX

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=